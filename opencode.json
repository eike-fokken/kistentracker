{
    "$schema": "https://opencode.ai/config.json",
    "lsp": {
        "pyright": {
            "disabled": true
        },
        "pylsp": {
            "command": [
                "poetry run pylsp"
            ],
            "extensions": [
                ".py",
                ".pyi"
            ]
        }
    },
    "provider": {
        "tensorx": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "TensorX",
            "options": {
                "baseURL": "https://api.tensorx.ai/v1",
                "apiKey": "{env:TENSORX_API_KEY}"
            },
            "models": {
                "deepseek/deepseek-v4-pro": {
                    "name": "deepseek V4 Pro",
                    "limit": {
                        "context": 131072,
                        "output": 16384
                    }
                }
            }
        }
    }
}
