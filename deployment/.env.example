# Copy to `.env` and fill in. `podman compose` reads this automatically.
#
# Tip: instead of editing by hand, generate a ready-to-use .env with:
#   ./generate-env.py                                             # local self-signed
#   ./generate-env.py --domain rentals.example.com --acme-email you@example.com
# It derives ALLOWED_HOSTS / CSRF origins (and a SECRET_KEY) for you.

# ---------------------------------------------------------------------------
# TLS / hostname
# ---------------------------------------------------------------------------
# Which Caddy config to mount. Local self-signed is the default; switch to the
# internet/Let's Encrypt config for a public deployment.
CADDYFILE=./Caddyfile.local
# CADDYFILE=./Caddyfile.internet

# Local deployment with a self-signed certificate (Caddy internal CA):
SITE_ADDRESS=localhost
ACME_EMAIL=

# Internet deployment with Let's Encrypt (uncomment and adjust, and set
# CADDYFILE=./Caddyfile.internet above):
# SITE_ADDRESS=rentals.example.com
# ACME_EMAIL=admin@example.com

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
# Generate one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me

# Hosts Django will answer for (comma-separated). Must match the hostname users
# actually connect to. Port-independent -- never add ":443"/":8443" here.
# `localhost` only works for local access; internet users need the real domain.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Full browser origins Django trusts for CSRF (comma-separated): scheme + host,
# plus a port ONLY when it is non-standard. The self-signed test runs on 8443:
DJANGO_CSRF_TRUSTED_ORIGINS=https://localhost:8443

# For an internet deployment on standard HTTPS (443), use the bare domain with
# NO port (a ":443" would stop the browser Origin from matching):
# DJANGO_ALLOWED_HOSTS=rentals.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://rentals.example.com
# You can list several, e.g. to keep local admin access alongside the domain:
# DJANGO_ALLOWED_HOSTS=rentals.example.com,localhost,127.0.0.1
# DJANGO_CSRF_TRUSTED_ORIGINS=https://rentals.example.com,https://localhost:8443

# Number of gunicorn workers (optional).
GUNICORN_WORKERS=3

# ---------------------------------------------------------------------------
# Ports
# ---------------------------------------------------------------------------
# Port gunicorn listens on and Caddy proxies to (backend:<BACKEND_PORT>).
BACKEND_PORT=8000
# Public ports Caddy publishes. Use 80/443 in production; high ports (e.g.
# 8080/8443) for a rootless local test. If HTTPS_PORT is non-standard, add it to
# the CSRF origin above.
HTTP_PORT=80
HTTPS_PORT=443
